DOPPLER_CONFIG=dev_vixen
DOPPLER_ENVIRONMENT=dev
DOPPLER_PROJECT=solana-pool-store-writer
ENABLE_OTLP_LOGS=true
FALKORDB_GRAPH_NAME=solana_pool_store_vixen
FALKOR_URL=http://localhost:6379
HTTP_PORT=3201
KAFKA_BROKERS=localhost:9094
KAFKA_CONSUMER_GROUP=solana_pool_store_writer_vixen
KAFKA_POOLS_V2_TOPIC=solana-api.indexer.v2
METRICS_PORT=28081
OTEL_ENABLE_ANSI_COLORS=true
OTEL_ENABLE_LOGS=true
OTEL_ENABLE_METRICS=true
OTEL_ENABLE_TRACING=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
OTEL_LOG_FORMATTING=compact
OTEL_METRIC_EXPORT_INTERVAL=1000
OTEL_PROPAGATORS=tracecontext
OTEL_RESOURCE_ATTRIBUTES=service.namespace=solana
OTEL_TRACES_SAMPLER=always_on
RUST_BACKTRACE=0
RUST_LOG=info
