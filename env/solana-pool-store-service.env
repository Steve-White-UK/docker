DISABLE_ANSI_COLORS=true
DOPPLER_CONFIG=dev_dev_test_environment
DOPPLER_ENVIRONMENT=dev
DOPPLER_PROJECT=solana-pool-store-service
ENABLE_DASH0_LOG_FORMATTING=true
ENABLE_OTLP_LOGS=true
