DOPPLER_CONFIG=dev_dev_test_environment
DOPPLER_ENVIRONMENT=dev
DOPPLER_PROJECT=solana-pool-indexer-redis-writer
ENABLE_OTLP_LOGS=true
HTTP_PORT=3011
KAFKA_BROKERS=localhost:9092
KAFKA_POOLS_TOPIC=solana-api.indexer.liquidity.raw.v0
KAFKA_PRICES_TOPIC=solana-api.indexer.prices.raw.v0
KAFKA_SCORES_TOPIC=solana-api.indexer.scores.raw.v0
KAFKA_TOKENS_TOPIC=solana-api.indexer.tokens.raw.v0
OTEL_ENABLE_ANSI_COLORS=true
OTEL_ENABLE_LOGS=true
OTEL_ENABLE_METRICS=true
OTEL_ENABLE_TRACING=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4317
OTEL_EXPORTER_OTLP_LOGS_ENDPOINT=http://otel-collector:4317
OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=http://otel-collector:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://otel-collector:4317
OTEL_LOG_FORMATTING=compact
OTEL_METRIC_EXPORT_INTERVAL=1000
OTEL_PROPAGATORS=tracecontext
OTEL_RESOURCE_ATTRIBUTES=service.namespace=solana
OTEL_TRACES_EXPORTER=otlp
OTEL_TRACES_SAMPLER=always_on
REDIS_URL=redis://localhost:6379
RUST_BACKTRACE=0
RUST_LOG=info
